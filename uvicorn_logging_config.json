{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "default": {
      "()": "uvicorn.logging.DefaultFormatter",
      "fmt": "%(levelprefix)s %(message)s",
      "use_colors": false
    },
    "access": {
      "()": "uvicorn_logging.NginxAccessFormatter",
      "fmt": "%(remote_addr)s - %(remote_user)s [%(asctime)s] \"%(request_line)s\" %(status_code)s %(body_bytes_sent)s \"%(http_referer)s\" \"%(http_user_agent)s\" \"%(http_x_forwarded_for)s\"",
      "datefmt": "%d/%b/%Y:%H:%M:%S %z",
      "use_colors": false
    }
  },
  "handlers": {
    "default": {
      "formatter": "default",
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stderr"
    },
    "access": {
      "formatter": "access",
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stdout"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["default"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.error": {
      "level": "INFO"
    },
    "uvicorn.access": {
      "handlers": ["access"],
      "level": "INFO",
      "propagate": false
    }
  }
}
